install.packages("tidyverse")
install.packages("tidyverse")
library(tidyverse)
#Input files folder should contains the following files: CoastalFires_LevoglucosanData.csv, CoastalFires_BiogeochemData.csv, CoastalFires_DischargeData.csv, CoastalFires_WatershedData.csv
input_folder <- "C:/Users/barto/OneDrive/Documents/GitHub/CoastalFires/Input" # Change this to match your directory. Make sure it ends in "/Input"
#working folder should contain: ReadMe.txt, CoastalFires_DataFrameWrangling.Rmd, and CoastalFires_DataAnalysis.Rmd
working_folder <- "C:/Users/barto/OneDrive/Documents/GitHub/CoastalFires/"  # Change this to match your directory.
#out put folder should not contain any files yet
output_folder <- "C:/Users/barto/OneDrive/Documents/GitHub/CoastalFires/Output" #Change this to match your directory. Make sure it ends in "/Output"
#From ESS-DIVE
LevoData <- readr::read_csv(file.path(input_folder, "CoastalFires_LevoglucosanData.csv"))
#From CUAHSI Hydroshare
BlackCarbonData <- readr::read_csv(file.path(input_folder, "CoastalFires_BiogeochemData.csv"))
WatershedData <- readr::read_csv(file.path(input_folder, "CoastalFires_WatershedData.csv"))
#combine data frames
CombinedData <- left_join(LevoData, BlackCarbonData, by = "Sample_ID")
#add watershed metadata and remove duplicated columns
CombinedData <- left_join(CombinedData, WatershedData, by = "Watershed")
CombinedData <- CombinedData %>% select(-Lat, -Long) #delete extra location columns
#dissolved black carbon (DBC) and dissolved organic carbon (DOC) are in micro grams of carbon per liter. To get both values into micro moles of carbon per liter, divide by mass of C atom to convert units into milli moles of C per liter (mM-C). Then multiply by 1000 to convert from mM-C to uM-C.
CombinedData$DOC_micro_mol_C_per_L <- CombinedData$DOC_mgC_per_L / 12 * 1000
CombinedData$DBC_micro_mol_C_per_L <- CombinedData$DBC_mgC_per_L / 12 * 1000
#individual BPCAs are in nano moles per liter (nM). Multiply by number of C atoms in molecule to convert units to nM-C.Then divide by 1000 to convert from nM-C to uM-C.
CombinedData$B6CA_micro_mol_C_per_L <- CombinedData$dB6CA_nano_mol_per_L * 12 / 1000 #B6CA, or benzenehexacarboxylic acid, has 12 C atoms
CombinedData$B5CA_micro_mol_C_per_L <- CombinedData$dB5CA_nano_mol_per_L * 11 / 1000 #B5CA, or benzenepentacarboxylic acid, has 12 C atoms
#Levoglucosan is in micro grams per liter. Divide by molecular weight of levoglucosan to get units into micro moles of levoglucosan per liter (uM). Then multiply by number of C atoms in the levoglucosan molecule to convert units to uM-C.
CombinedData$Levo_micro_mol_C_per_L <- CombinedData$levo_micro_gram_per_liter / 162.14 * 6 #levoglucosan has six C atoms in its structure
#Add a new column that calculates the concentration of both B6CA and B5CA molecular markers. To avoid bias (due to conversion factors associated with calculating black carbon concentrations with BPCAs) when comparing black carbon and levoglucosan, we use the combined concentration of B6CA and B5CA.
CombinedData$B6CA_and_B5CA_micro_mol_C_per_L <- CombinedData$B6CA_micro_mol_C_per_L + CombinedData$B5CA_micro_mol_C_per_L
#calculate the ratio of levoglucosan to bulk DOC and BPCA to DOC
CombinedData$Levo_DOC_percent <- CombinedData$Levo_micro_mol_C_per_L / CombinedData$DOC_micro_mol_C_per_L * 100
CombinedData$BPCA_DOC_percent <- CombinedData$B6CA_and_B5CA_micro_mol_C_per_L / CombinedData$DOC_micro_mol_C_per_L * 100
#Ensuring that the Date column is correctly classified as a date rather than a character
CombinedData$Date <- as.Date(CombinedData$Date, format = "%d-%b-%y")
#Calculating the time since fire for all samples and ensuring it is a numeric value
fire_date <- as.Date("2020-08-16")
CombinedData$time_since_fire_day <- as.numeric(CombinedData$Date - fire_date)
#Remove unnecessary columns. The columns that are being removed with the following script are associated with the particulate phase (i.e., particulate organic carbon and particulate black carbon). As levoglucosan concentrations were determined only for the dissolved phase, the following data analysis will also only focus on the dissolved phase.
CombinedData <- CombinedData %>%
select(-TSS_mg_per_L, -POC_mgC_per_L, -`PBC_mgC_per_L`, -PBC_TSS_percent,
-PBC_POC_percent, -pB6CA_nano_mol_per_L, -pB5CA_nano_mol_per_L, -pB6CA_B5CA, -Flow_category)
#Remove levoglucosan, DBC, BPCA, and DOC columns with old units
CombinedData <- CombinedData %>%
select(-DOC_mgC_per_L, -DBC_mgC_per_L, -dB6CA_nano_mol_per_L, -dB5CA_nano_mol_per_L,
-levo_micro_gram_per_liter, -std_levo_micro_gram_per_liter)
# Specify the desired column order
desired_order <- c("Sample_ID", "Watershed", "Date", "Time", "time_since_fire_day", "Latitude", "Longitude", "Location_Change",
"Discharge_cms", "DOC_micro_mol_C_per_L", "Levo_micro_mol_C_per_L", "B6CA_micro_mol_C_per_L",
"B5CA_micro_mol_C_per_L", "B6CA_and_B5CA_micro_mol_C_per_L", "dB6CA_B5CA",
"Levo_DOC_percent", "BPCA_DOC_percent", "DBC_micro_mol_C_per_L", "DBC_DOC_percent",
"a254_per_m", "SUVA254_L_per_mgC_per_m",
"Area_square_kilometer", "Average_slope_percent",
"Average_precipitation_milli_meter", "Burn_Extent_percent",
"Area_low_severity_percent", "Area_low_to_mod_severity_percent",
"Area_mod_to_high_severity_percent", "Forest_percent",
"Shrub_percent", "Developed_percent",
"Sandstone_and_sedimentary_percent", "Igneous_percent",
"Suficial_Sediments_percent", "Schist_percent")
# Rearrange the columns
CombinedData <- CombinedData[, desired_order]
write.csv(CombinedData,
file = file.path(output_folder, "CoastalFires_CombinedData.csv"),
row.names = FALSE)  #Prevents writing row numbers
install.packages("gt")
install.packages("Cairo")
install.packages("gt")
install.packages("ggrepel")
install.packages("vegan")
install.packages("tidyverse")
install.packages("tidyverse")
library(gt)
library(Cairo)
library(ggrepel)
library(vegan)
library(tidyverse)
#Input folder should contains the following files: CoastalFires_DischargeData.csv
input_folder <- "C:/Users/barto/OneDrive/Documents/GitHub/CoastalFires/Input" # Change this to match your data frame location. Make sure it ends in "/Input"
#Working folder should contains the following files:
#From ESS-DIVE: CoastalFires_DataAnalysis.Rmd
working_folder <- "C:/Users/barto/OneDrive/Documents/GitHub/CoastalFires/"  # Change this to match your scripts location
#out put folder should contain a csv created with the DataFrameWrangling script: "CoastalFires_CombinedData.csv"
output_folder <- "C:/Users/barto/OneDrive/Documents/GitHub/CoastalFires/Output" #Change this to match your directory
CombinedData <- readr::read_csv(file.path(output_folder,"CoastalFires_CombinedData.csv"))
#Scott Creek flooded during the events of January 27-28th, 2021. Samples were collected at a downstream lagoon site. However, due to this the data collected does not accurately reflect that at the sample site. As such authors of the associated manuscript have excluded it from all data analysis and figure creation.
CombinedData <- CombinedData %>%
filter(Location_Change != "Y")
CombinedData$Q_norm_levo <- CombinedData$Levo_micro_mol_C_per_L / CombinedData$Discharge_cms #units are in uM-C s per m^(-3)
# List of variables to summarize
vars_to_summarize <- c("DOC_micro_mol_C_per_L", "Levo_micro_mol_C_per_L", "B6CA_and_B5CA_micro_mol_C_per_L",
"Levo_DOC_percent", "BPCA_DOC_percent", "SUVA254_L_per_mgC_per_m", "a254_per_m")
# Function to calculate summary stats for one variable
summary_stats <- function(var) {
x <- CombinedData[[var]]
x <- x[!is.na(x)]  # remove NAs
data.frame(
Variable = var,
Min = min(x),
Max = max(x),
Mean = mean(x),
SD = sd(x),
Median = median(x)
)
}
# Apply function to all variables
summary_table <- do.call(rbind, lapply(vars_to_summarize, summary_stats))
# View the summary
print(summary_table)
#are all variables normally distributed?
#filter to only numeric data
numeric_columns <- sapply(CombinedData, is.numeric)
Data_numeric <- CombinedData[, numeric_columns]
Data_numeric <- Data_numeric %>% select(-Latitude, -Longitude)
# Apply Shapiro-Wilk test and create a readable summary
shapiro_results <- sapply(Data_numeric, function(x) {
test <- shapiro.test(x)
return(c(p_value = test$p.value, W = test$statistic))
})
# Convert results to a data frame
shapiro_df <- as.data.frame(t(shapiro_results))
shapiro_df$Variable <- rownames(shapiro_df)
rownames(shapiro_df) <- NULL
# Print readable results
print(shapiro_df)
# Ensure Watershed is a factor
CombinedData$Watershed <- as.factor(CombinedData$Watershed)
# Filter to numeric data (excluding lat/long again)
numeric_columns <- sapply(CombinedData, is.numeric)
Data_numeric <- CombinedData[, numeric_columns]
Data_numeric <- Data_numeric %>% select(-Latitude, -Longitude)
# Run Kruskal-Wallis test for each numeric variable by Watershed
kruskal_results <- sapply(names(Data_numeric), function(var) {
formula <- as.formula(paste(var, "~ Watershed"))
test <- kruskal.test(formula, data = CombinedData)
return(c(p_value = test$p.value, chi_squared = test$statistic))
})
# Convert to readable data frame
kruskal_df <- as.data.frame(t(kruskal_results))
kruskal_df$Variable <- rownames(kruskal_df)
rownames(kruskal_df) <- NULL
# Print the results
print(kruskal_df)
#According to the above Kruskal Wallis tests, the following variables are significantly different between watersheds: Q_norm_levo, BPCA_DOC_percent, and dB6CA_B5CA
# Make sure Watershed is a factor
CombinedData$Watershed <- as.factor(CombinedData$Watershed)
# Variables to test
vars_to_test <- c("Q_norm_levo", "BPCA_DOC_percent", "dB6CA_B5CA")
# Get all unique pairwise combinations of watersheds
watershed_pairs <- combn(levels(CombinedData$Watershed), 2, simplify = FALSE)
# Initialize an empty list to store results
wilcox_results <- list()
# Loop through each variable and watershed pair
for (var in vars_to_test) {
for (pair in watershed_pairs) {
# Extract and unlist group data
group1 <- CombinedData[CombinedData$Watershed == pair[1], var]
group2 <- CombinedData[CombinedData$Watershed == pair[2], var]
# Unlist and convert to numeric, removing NA values
group1 <- as.numeric(unlist(group1))
group2 <- as.numeric(unlist(group2))
group1 <- group1[!is.na(group1)]
group2 <- group2[!is.na(group2)]
# Only test if both groups have data
if (length(group1) > 0 & length(group2) > 0) {
test <- wilcox.test(group1, group2)
wilcox_results[[length(wilcox_results) + 1]] <- data.frame(
Variable = var,
Watershed_1 = pair[1],
Watershed_2 = pair[2],
p_value = test$p.value,
W_statistic = test$statistic
)
}
}
}
# Combine results into a single data frame
wilcox_df <- do.call(rbind, wilcox_results)
# Print
print(wilcox_df)
# Variables to test against time_since_fire
vars_to_test_time_since_fire <- c("DOC_micro_mol_C_per_L", "Levo_micro_mol_C_per_L", "B6CA_and_B5CA_micro_mol_C_per_L", "Levo_DOC_percent", "BPCA_DOC_percent", "Q_norm_levo", "SUVA254_L_per_mgC_per_m", "a254_per_m")
# Initialize a list to store results
spearman_results_time_since_fire <- lapply(vars_to_test_time_since_fire, function(var) {
# Extract x and y, remove rows with NA
df <- CombinedData[, c("time_since_fire_day", var)]
df <- na.omit(df)
# Run Spearman correlation test
test <- cor.test(df$time_since_fire_day, df[[var]], method = "spearman")
# Return results as a row in a data frame
data.frame(
Variable = var,
Spearman_rho = test$estimate,
p_value = test$p.value,
stringsAsFactors = FALSE
)
})
# Combine into a single data frame
spearman_df_time_since_fire <- do.call(rbind, spearman_results_time_since_fire)
# Print results
print(spearman_df_time_since_fire)
# Variables to test against discharge
vars_to_test_Q <- c("DOC_micro_mol_C_per_L", "Levo_micro_mol_C_per_L", "B6CA_and_B5CA_micro_mol_C_per_L", "Levo_DOC_percent", "BPCA_DOC_percent", "SUVA254_L_per_mgC_per_m", "a254_per_m")
# Initialize a list to store results
spearman_results_Q <- lapply(vars_to_test_Q, function(var) {
# Extract x and y, remove rows with NA
df <- CombinedData[, c("Discharge_cms", var)]
df <- na.omit(df)
# Run Spearman correlation test
test <- cor.test(df$Discharge_cms, df[[var]], method = "spearman")
# Return results as a row in a data frame
data.frame(
Variable = var,
Spearman_rho = test$estimate,
p_value = test$p.value,
stringsAsFactors = FALSE
)
})
# Combine into a single data frame
spearman_df_Q <- do.call(rbind, spearman_results_Q)
# Print results
print(spearman_df_Q)
# Variables to test against Levo_micro_mol_C_per_L
vars_to_test_levo_conc <- c("Area_square_kilometer", "Average_slope_percent", "Average_precipitation_milli_meter", "Burn_Extent_percent", "Area_low_severity_percent", "Area_low_to_mod_severity_percent", "Area_mod_to_high_severity_percent", "Forest_percent", "Shrub_percent", "Developed_percent", "Sandstone_and_sedimentary_percent", "Igneous_percent", "Suficial_Sediments_percent", "Schist_percent")
# Initialize a list to store results
spearman_results_levo_conc <- lapply(vars_to_test_levo_conc, function(var) {
