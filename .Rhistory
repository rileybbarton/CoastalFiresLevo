LevoData <- readr::read_csv("CoastalFires_Levo.csv")
PublishedData <- readr::read_csv("CoastalFires_PublishedData.csv")
#delete excess columns
LevoData <- LevoData %>% select(-relative_area_levo, -relative_amount_levo, -levoglucosan_area, -C13_levoglucosan_area, -c13_levo_ppb)
#rearrange columns to get sample_id and replicate number
library(stringr)
LevoData$sample_id <- str_extract(LevoData$header, "(?<=-).*")
LevoData$replicate <- str_extract(LevoData$header, "(?<=R)[0-2]+")
#remove non-data (i.e., standards)
LevoData <- LevoData %>% filter(!is.na(replicate))
#remove a naming error
LevoData[LevoData == 'SAN-7DUP'] <- 'SAN-7'
#average replicates
LevoData <- LevoData %>% group_by(sample_id) %>% summarize(avg_levo_ppb=mean(levo_ppb))
print(LevoData)
#adjust the published data frame
#remove excess columns and print
PublishedData <- PublishedData %>% select(-TSS_mg_per_L, -POC_mgC_per_L, -PBC_mgC_per_L, -PBC_TSS_perc, -PBC_POC_perc, -pB6CA_nM,-pB5CA_nM, -pB6CA_B5CA)
print(PublishedData)
#combine data frames
Data <- left_join(LevoData, PublishedData, by = "sample_id")
#rearrange column order to move levo_ppb after DOC
Data <- Data %>% select(sample_id, replicate, watershed, date, time, lat, long, Q_m_sq_per_sec, flow_cat, lagoon, DOC_mgC_per_L, levo_ppb, DBC_mgC_per_L, everything())
#combine data frames
Data <- left_join(LevoData, PublishedData, by = "sample_id")
#rearrange column order to move levo_ppb after DOC
Data <- Data %>% select(sample_id, watershed, date, time, lat, long, Q_m_sq_per_sec, flow_cat, lagoon, DOC_mgC_per_L, levo_ppb, DBC_mgC_per_L, everything())
#combine data frames
Data <- left_join(LevoData, PublishedData, by = "sample_id")
#rearrange column order to move levo_ppb after DOC
Data <- Data %>% select(sample_id, watershed, date, time, lat, long, Q_m_sq_per_sec, flow_cat, lagoon, DOC_mgC_per_L, avg_levo_ppb, DBC_mgC_per_L, everything())
#print new combined data frame to be used for data analysis
print(Data)
#calculate the ratio of levoglucosan to bulk DOC and DBC
Data$Levo_DOC_perc <- Data$levo_ppb/1000/Data$DOC_mgC_per_L*100
#calculate the ratio of levoglucosan to bulk DOC and DBC
Data$Levo_DOC_perc <- Data$avg_levo_ppb/1000/Data$DOC_mgC_per_L*100
Data$Levo_DBC <- Data$avg_levo_ppb/1000/Data$DBC_mgC_per_L
print(Data)
#are all variables normally distributed?
#filter to only numeric data
numeric_columns <- sapply(Data, is.numeric)
Data_numeric <- Data[, numeric_columns]
Data_numeric <- Data_numeric %>% select(-lat, -long)
# Apply Shapiro-Wilk test and create a readable summary
shapiro_results <- sapply(Data_numeric, function(x) {
test <- shapiro.test(x)
return(c(p_value = test$p.value, W = test$statistic))
})
# Convert results to a data frame
shapiro_df <- as.data.frame(t(shapiro_results))
shapiro_df$Variable <- rownames(shapiro_df)
rownames(shapiro_df) <- NULL
# Print readable results
print(shapiro_df)
#is the concentration of levoglucosan different across watersheds?
kruskal_test_levo <- kruskal.test(avg_levo_ppb ~ watershed, data = Data)
print(kruskal_test_levo)
#is the ratio of levoglucosan to bulk DOC different across watersheds?
kruskal_test_levotoDOC <- kruskal.test(Levo_DOC_perc ~ watershed, data = Data)
print(kruskal_test_levotoDOC)
#is the ratio of levoglucosan to DBC different across watersheds?
kruskal_test_levotoDBC <- kruskal.test(Levo_DBC ~ watershed, data = Data)
print(kruskal_test_levotoDBC)
#Ensuring that the Date column is correctly classified as a date rather than a character
Data$date <- as.Date(Data$date, format = "%d-%b-%y")
#Calculating the time since fire for all samples and ensuring it is a numeric value
fire_date <- as.Date("2020-08-16")
Data$time_since_fire_day <- as.numeric(Data$date - fire_date)
#Prevent ties by averaging all data with levoglucosan replicates
Data_numeric <- Data %>%
select_if(is.numeric)
# Use the aggregate function to average replicates for numeric columns
Data_avg <- Data %>%
group_by(sample_id) %>%
summarise(across(where(is.numeric), mean, na.rm = TRUE),
watershed = first(watershed))
#make a table to showcase the coefficients and p-values
# Perform Spearman's rank correlation using the averaged data
spearman_corr_levo_ppb <- cor.test(Data_avg$time_since_fire_day, Data_avg$levo_ppb, method = "spearman", use = "pairwise.complete.obs")
#Ensuring that the Date column is correctly classified as a date rather than a character
Data$date <- as.Date(Data$date, format = "%d-%b-%y")
#Calculating the time since fire for all samples and ensuring it is a numeric value
fire_date <- as.Date("2020-08-16")
Data$time_since_fire_day <- as.numeric(Data$date - fire_date)
#make a table to showcase the coefficients and p-values
# Perform Spearman's rank correlation using the averaged data
spearman_corr_levo_ppb <- cor.test(Data_avg$time_since_fire_day, Data_avg$levo_ppb, method = "spearman", use = "pairwise.complete.obs")
#Ensuring that the Date column is correctly classified as a date rather than a character
Data$date <- as.Date(Data$date, format = "%d-%b-%y")
#Calculating the time since fire for all samples and ensuring it is a numeric value
fire_date <- as.Date("2020-08-16")
Data$time_since_fire_day <- as.numeric(Data$date - fire_date)
#make a table to showcase the coefficients and p-values
# Perform Spearman's rank correlation using the averaged data
spearman_corr_levo_ppb <- cor.test(Data_avg$time_since_fire_day, Data_avg$avg_levo_ppb, method = "spearman", use = "pairwise.complete.obs")
spearman_corr_levoDOC <- cor.test(Data_avg$time_since_fire_day, Data_avg$Levo_DOC_perc, method = "spearman", use = "pairwise.complete.obs")
spearman_corr_levoDBC <- cor.test(Data_avg$time_since_fire_day, Data_avg$Levo_DBC, method = "spearman", use = "pairwise.complete.obs")
# Extract p-values and rho values
results <- data.frame(
Comparison = c("time_since_fire_day vs levo_ppb",
"time_since_fire_day vs levoDOC",
"time_since_fire_day vs levodbc"),
Rho = c(spearman_corr_levo_ppb$estimate,
spearman_corr_levoDOC$estimate,
spearman_corr_levoDBC$estimate),
P_Value = c(spearman_corr_levo_ppb$p.value,
spearman_corr_levoDOC$p.value,
spearman_corr_levoDBC$p.value)
)
# Print the results table
print(results)
